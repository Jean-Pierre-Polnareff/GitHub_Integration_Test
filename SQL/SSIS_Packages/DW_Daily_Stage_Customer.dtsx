      DTS:LocaleID="-1">
      <DTS:Variables>
        <DTS:Variable
          DTS:CreationName=""
          DTS:Description="The propagate property of the event"
          DTS:DTSID="{6CD23046-BB6A-46AF-9E37-5B01B04B66B1}"
          DTS:IncludeInDebugDump="6789"
          DTS:Namespace="System"
          DTS:ObjectName="Propagate">
          <DTS:VariableValue
            DTS:DataType="11">-1</DTS:VariableValue>
        </DTS:Variable>
      </DTS:Variables>
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package.EventHandlers[OnInformation]\LogRowCount"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{88B1D95C-F0DE-4E91-B833-4640D6366AED}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="LogRowCount">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{64CB5D2C-2FA7-4D67-A511-82272B608113}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource=" &#xA;SET NOCOUNT ON &#xA;&#xA;DECLARE @packagename VARCHAR(50); SET @packagename = ?&#xA;DECLARE @sourcename VARCHAR(50); SET @sourcename = ?&#xA;DECLARE @taskname VARCHAR(50); SET @taskname = ?&#xA;DECLARE @message VARCHAR(50); SET @message = ?&#xA;DECLARE @executioninstanceguid VARCHAR(50); SET @executioninstanceguid = ?&#xA;&#xA;IF (@message like '%wrote%' and @message like '%rows%') &#xA;BEGIN &#xA; IF NOT EXISTS (SELECT 1 FROM PackageInstance &#xA;     WHERE packagename = @packagename &#xA;      AND executioninstanceguid = @executioninstanceguid)  &#xA; BEGIN &#xA;  INSERT INTO PackageInstance &#xA;  (packagename, executioninstanceguid) &#xA;  VALUES &#xA;  (@packagename, @executioninstanceguid) &#xA; END &#xA;&#xA; INSERT INTO PackageMessageLog &#xA; (packagename, sourcename, taskname, [message], executioninstanceguid, update_time)&#xA; VALUES &#xA; (@packagename, @sourcename, @taskname, @message, @executioninstanceguid, getdate()) &#xA;&#xA; -- parse message &#xA; DECLARE @rows_coming VARCHAR(50); SET @rows_coming = (SELECT NameValue FROM (SELECT CASE WHEN try_parse(replace(replace(replace(value,'wrote',''),'rows',''),'.','') AS INT) IS NULL THEN 0 ELSE 1 END KeyValue, &#xA;       replace(replace(replace(value,'wrote',''),'rows',''),'.','') NameValue  &#xA;      FROM string_split(@message,'&quot;') &#xA;      WHERE value != '') t WHERE KeyValue = 1)&#xA;&#xA; DECLARE @entity varchar(100); set @entity = (SELECT NameValue FROM (SELECT CASE WHEN  try_parse(replace(replace(replace(value,'wrote',''),'rows',''),'.','') AS INT) IS NULL THEN 0 ELSE 1 END KeyValue, &#xA;       replace(replace(replace(value,'wrote',''),'rows',''),'.','') NameValue  &#xA;      FROM string_split(@message,'&quot;') &#xA;      WHERE value != '') t WHERE KeyValue = 0)&#xA;&#xA; DECLARE @rows INT; SET @rows = try_parse(@rows_coming as int) &#xA;&#xA; IF PATINDEX('-', @entity) &gt; 0 &#xA; BEGIN &#xA;  declare @server varchar(50); &#xA;&#xA;  select @server = value  &#xA;  from (&#xA;  select *, ROW_NUMBER() over (order by @entity) r  &#xA;  FROM string_split(@entity,'-') &#xA;  ) t &#xA;  WHERE r = 1 &#xA;&#xA;  select @entity = value  &#xA;  from (&#xA;  select *, ROW_NUMBER() over (order by @entity) r  &#xA;  FROM string_split(@entity,'-') &#xA;  ) t &#xA;  WHERE r = 2 &#xA;  &#xA;  select @server, @entity &#xA; END &#xA;&#xA; IF @entity is not null&#xA; BEGIN &#xA;  IF EXISTS (SELECT 1 FROM PackageCounters WHERE packagename = @packagename and @sourcename = sourcename and @entity = taskname and executioninstanceguid = @executioninstanceguid) &#xA;  BEGIN &#xA;   UPDATE P  &#xA;   SET Rows_Processing = @rows  &#xA;   FROM PackageCounters p &#xA;   WHERE packagename = @packagename and @sourcename = sourcename and @entity = taskname and executioninstanceguid = @executioninstanceguid &#xA;  END &#xA;  ELSE &#xA;  BEGIN &#xA;   INSERT INTO PackageCounters &#xA;   (packagename,sourcename,taskname,executioninstanceguid,Rows_Processing)&#xA;   VALUES &#xA;   (@packagename,@sourcename,@entity,@executioninstanceguid,@rows )&#xA;  END &#xA; END &#xA;&#xA; DECLARE @space AS TABLE(name VARCHAR(50), rows INT, reserved VARCHAR(50), data VARCHAR(50), index_size VARCHAR(50), unused VARCHAR(50)) &#xA; INSERT INTO @space &#xA; EXEC sp_spaceused @entity &#xA;&#xA; UPDATE P  &#xA; SET Rows_Final = s.rows  &#xA; FROM PackageCounters p &#xA;  JOIN @space s ON s.name = p.taskname &#xA; WHERE packagename = @packagename and sourcename =  @sourcename and taskname = @entity and executioninstanceguid = @executioninstanceguid &#xA;&#xA;END &#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="System::PackageName"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="129"
                SQLTask:ParameterSize="50" />
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="1"
                SQLTask:DtsVariableName="System::SourceName"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="129"
                SQLTask:ParameterSize="50" />
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="2"
                SQLTask:DtsVariableName="System::TaskName"
